{
  "buildCommand": "pnpm build && npx prisma generate",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "vite",
  "outputDirectory": "dist",
  "nodeVersion": "18.x",
  "env": {
    "DATABASE_URL": {
      "description": "PostgreSQL connection string from NeonDB (required)",
      "required": true
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT signing (required)",
      "required": true
    },
    "FRONTEND_URL": {
      "description": "Frontend URL for CORS (required)",
      "required": true
    },
    "NODE_ENV": {
      "value": "production",
      "required": true
    },
    "PORT": {
      "value": "3000"
    },
    "JWT_EXPIRES_IN": {
      "value": "7d"
    },
    "OPENAI_API_KEY": {
      "description": "OpenAI API key (at least one AI provider required)"
    },
    "GEMINI_API_KEY": {
      "description": "Google Gemini API key (at least one AI provider required)"
    },
    "ANTHROPIC_API_KEY": {
      "description": "Anthropic Claude API key (at least one AI provider required)"
    },
    "MISTRAL_API_KEY": {
      "description": "Mistral API key"
    },
    "GROQ_API_KEY": {
      "description": "Groq API key"
    },
    "COHERE_API_KEY": {
      "description": "Cohere API key"
    },
    "PERPLEXITY_API_KEY": {
      "description": "Perplexity API key"
    },
    "TOGETHER_API_KEY": {
      "description": "Together AI API key"
    },
    "HUGGINGFACE_API_KEY": {
      "description": "HuggingFace API key"
    },
    "DEEPSEEK_API_KEY": {
      "description": "DeepSeek API key"
    },
    "CLOUDINARY_CLOUD_NAME": {
      "description": "Cloudinary cloud name (optional)"
    },
    "CLOUDINARY_API_KEY": {
      "description": "Cloudinary API key (optional)"
    },
    "CLOUDINARY_API_SECRET": {
      "description": "Cloudinary API secret (optional)"
    },
    "WHISPER_API_KEY": {
      "description": "OpenAI Whisper API key (optional)"
    }
  },
  "functions": {
    "api/**": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
